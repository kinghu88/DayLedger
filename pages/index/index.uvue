	}

	.legend-dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		margin-right: 8px;
	}

	.legend-text {
		font-size: 12px;
		color: #64748b;
	}

	.transactions-list {
		margin-top: 12px;
	}

	.transaction-item {
		flex-direction: row;
		justify-content: space-between;
