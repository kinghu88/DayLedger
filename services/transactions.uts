export type TransactionType = 'income' | 'expense'

export type Transaction = {
	id: string
	type: TransactionType
	amount: number
	category: string
	description: string
	note?: string
	date: string
	iconText?: string
	iconBg?: string
	iconColor?: string
	iconKind?: string
}

const STORAGE_KEY = 'transactions'

function safeParseArray(value: string): any[] {
	try {
		const parsed = JSON.parseArray(value)
		return parsed != null ? parsed : []
	} catch (e) {
		return []
	}
}

function toText(value: any): string {
	if (value == null) return ''
	return `${value}`
}

function readAny(raw: any, key: string): any | null {
	if (raw == null) return null
	if (raw instanceof UTSJSONObject) {
		return raw.getAny(key)
	}
	try {
		const obj = JSON.parseObject(JSON.stringify(raw))
		if (obj == null) return null
		return obj.getAny(key)
	} catch (e) {
		return null
	}
}

function normalizeTransaction(raw: any): Transaction | null {
	if (raw == null) return null
	const id = toText(readAny(raw, 'id'))
	if (id.length === 0) return null
	const typeText = toText(readAny(raw, 'type'))
	const type = (typeText.length > 0 ? typeText : 'expense') as TransactionType
	const rawAmount = readAny(raw, 'amount')
	const amount = rawAmount != null ? Number(rawAmount) : 0
	const category = toText(readAny(raw, 'category'))
	let description = toText(readAny(raw, 'description'))
	if (description.length === 0) description = toText(readAny(raw, 'note'))
	const date = toText(readAny(raw, 'date'))
	if (date.length === 0) return null
	if (isNaN(amount)) return null
	if (amount <= 0) return null
	if (type !== 'income' && type !== 'expense') return null

	const tx: Transaction = {
		id,
		type,
		amount,
		category,
		description,
		date
	}

	const note = toText(readAny(raw, 'note'))
	if (note.length > 0) tx.note = note
	const iconText = toText(readAny(raw, 'iconText'))
	if (iconText.length > 0) tx.iconText = iconText
	const iconBg = toText(readAny(raw, 'iconBg'))
	if (iconBg.length > 0) tx.iconBg = iconBg
	const iconColor = toText(readAny(raw, 'iconColor'))
	if (iconColor.length > 0) tx.iconColor = iconColor
	const iconKind = toText(readAny(raw, 'iconKind'))
	if (iconKind.length > 0) tx.iconKind = iconKind
	return tx
}

