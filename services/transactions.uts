export function getTransactions(): Transaction[] {
	const stored = uni.getStorageSync(STORAGE_KEY) as string | null
	if (stored == null) return []
	if (stored.length === 0) return []
	const arr = safeParseArray(stored)
	const result: Transaction[] = []
	for (let i = 0; i < arr.length; i++) {
		const tx = normalizeTransaction(arr[i])
		if (tx != null) result.push(tx)
	}
	return result
}

export function setTransactions(list: Transaction[]): void {
	uni.setStorageSync(STORAGE_KEY, JSON.stringify(list))
}

export function getTransactionById(id: string): Transaction | null {
	const list = getTransactions()
	const found = list.find((t: Transaction) => t.id === id)
	return found ? found : null
}

export function addTransaction(tx: any): Transaction | null {
	const normalized = normalizeTransaction(tx)
	if (normalized == null) return null
	const list = getTransactions()
	list.push(normalized)
	setTransactions(list)
	return normalized
}

export function updateTransactionById(id: string, updater: (prev: Transaction) => any): Transaction | null {
	const list = getTransactions()
	const idx = list.findIndex((t: Transaction) => t.id === id)
	if (idx < 0) return null
	const nextRaw = updater(list[idx])
	const normalized = normalizeTransaction(nextRaw)
	if (normalized == null) return null
	list[idx] = normalized
	setTransactions(list)
	return normalized
}

export function deleteTransactionById(id: string): boolean {
	const list = getTransactions()
	const next = list.filter((t: Transaction) => t.id !== id)
	if (next.length === list.length) return false
	setTransactions(next)
	return true
}

export function removeExpense(id: string): boolean {
	if (id.length === 0) return false
	const list = getTransactions()
	const target = list.find((t: Transaction) => t.id === id)
	if (target == null) return false
	const next = list.filter((t: Transaction) => t.id !== id)
	if (next.length === list.length) return false
	setTransactions(next)
	return true
}

export function exportTransactionsJson(pretty: boolean): string {
	const list = getTransactions()
	if (pretty) return JSON.stringify(list, null, 2)
	return JSON.stringify(list)
}
